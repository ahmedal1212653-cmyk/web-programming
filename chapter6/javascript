<!DOCTYPE html>
<html>
<head>
  <title>Petrol Calculator</title>

  <style>
    /* ===== Page layout styling ===== */
    body {
      font-family: Arial;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    /* ===== Container box ===== */
    .container {
      border: 1px solid #000;
      padding: 20px;
      width: 250px;
      text-align: center;
    }

    /* ===== Input fields ===== */
    input {
      width: 100%;
      margin: 10px 0;
      padding: 5px;
    }

    /* Focus effect when selecting input */
    input:focus {
      outline: 2px solid blue;
    }

    /* ===== Button styling ===== */
    button {
      width: 100%;
      padding: 8px;
      cursor: pointer;
    }

    /* Hover effect for button */
    button:hover {
      background-color: lightgray;
    }
  </style>
</head>

<body>

  <div class="container">

    <!-- Title -->
    <h3>Petrol Calculator</h3>

    <!-- Petrol price input (default 1.72) -->
    <input type="number" id="price" value="1.72">

    <!-- Liters input (default 0) -->
    <input type="number" id="liters" value="0">

    <!-- Calculate button -->
    <button onclick="calculate()">Calculate</button>

    <!-- Result display -->
    <p id="result">Total: 0</p>

  </div>

  <script>
    /* Function to calculate petrol cost */
    function calculate() {
      // Get values from inputs
      let price = document.getElementById("price").value;
      let liters = document.getElementById("liters").value;

      // Calculate total
      let total = price * liters;

      // Display result in paragraph
      document.getElementById("result").innerText = "Total: " + total;
    }
  </script>

</body>
</html>
